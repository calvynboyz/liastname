<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Member List - DERECK168</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background: linear-gradient(to bottom, #2b0a0a, #121212);
            min-height: 100vh;
            color: white;
            font-family: 'Inter', sans-serif;
        }
        .member-card {
            background-color: rgba(45, 20, 20, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: transform 0.2s;
        }
        .member-card:hover {
            transform: translateY(-5px);
            background-color: rgba(60, 25, 25, 0.8);
        }
    </style>
</head>
<body>

    <nav class="flex justify-between items-center px-10 py-5">
        <div class="text-2xl font-bold tracking-widest">DERECK168</div>
        <div class="space-x-6 text-sm">
            <a href="#" class="text-gray-300 hover:text-white border-b-2 border-red-600 pb-1">Members</a>
            <a href="#" class="text-gray-400 hover:text-white">Admin</a>
        </div>
    </nav>

    <header class="text-center mt-10 mb-16">
        <h2 class="text-6xl font-black text-white/10 absolute left-1/2 -translate-x-1/2 -mt-8 tracking-[1rem] uppercase">Memberlist</h2>
        <h1 class="text-4xl font-bold relative z-10 tracking-widest">DERECK</h1>
        
        <div class="mt-10 max-w-md mx-auto relative">
            <span class="absolute inset-y-0 left-3 flex items-center text-gray-400">
                <i class="fas fa-search"></i>
            </span>
            <input type="text" placeholder="Search code name..." 
                class="w-full bg-black/40 border border-gray-700 rounded-full py-2 pl-10 pr-4 focus:outline-none focus:border-red-600 transition">
        </div>
    </header>

    <main class="max-w-6xl mx-auto px-4 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        
        <div class="member-card rounded-2xl p-8 text-center">
            <div class="w-24 h-24 mx-auto mb-4 rounded-full border-2 border-red-600 overflow-hidden bg-gray-800">
                <img src="https://via.placeholder.com/150" alt="profile" class="w-full h-full object-cover">
            </div>
            <h3 class="text-lg font-semibold">Taro Winterfell</h3>
            <p class="text-xs text-gray-400 mb-4 tracking-tighter">DERECK</p>
            <a href="#" class="text-blue-500 hover:text-blue-400 text-2xl">
                <i class="fab fa-facebook"></i>
            </a>
        </div>

        <div class="member-card rounded-2xl p-8 text-center">
            <div class="w-24 h-24 mx-auto mb-4 rounded-full border-2 border-red-600 overflow-hidden bg-gray-800">
                <img src="https://via.placeholder.com/150" alt="profile" class="w-full h-full object-cover">
            </div>
            <h3 class="text-lg font-semibold">Park Winterfell</h3>
            <p class="text-xs text-gray-400 mb-4 tracking-tighter">DERECK</p>
            <a href="#" class="text-blue-500 hover:text-blue-400 text-2xl">
                <i class="fab fa-facebook"></i>
            </a>
        </div>

        </main>

    <footer class="flex justify-center items-center space-x-2 my-12">
        <button class="w-8 h-8 flex items-center justify-center text-gray-400 hover:text-white"><i class="fas fa-chevron-left text-xs"></i></button>
        <button class="w-8 h-8 rounded-full bg-red-600 text-white text-sm">1</button>
        <button class="w-8 h-8 rounded-full hover:bg-white/10 text-sm">2</button>
        <button class="w-8 h-8 rounded-full hover:bg-white/10 text-sm">3</button>
        <span class="text-gray-500">...</span>
        <button class="w-8 h-8 rounded-full hover:bg-white/10 text-sm">20</button>
        <button class="w-8 h-8 flex items-center justify-center text-gray-400 hover:text-white"><i class="fas fa-chevron-right text-xs"></i></button>
    </footer>

</body>
</html>
